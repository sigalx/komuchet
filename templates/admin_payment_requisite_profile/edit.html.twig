{% extends 'admin/base.html.twig' %}

{% block title %}Изменить Реквизиты {{ payment_requisite_profile.name }}{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Изменить реквизиты {{ payment_requisite_profile.name }}</h1>
            <p class="text-secondary mb-0">Изменения попадут только в новые квитанции. Уже сохраненные квитанции не пересчитываются.</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_payment_requisite_profile_show', {'uuid': payment_requisite_profile.uuid}) }}">К карточке</a>
    </div>

    <section class="card">
        <div class="card-body">
            {{ include('admin_payment_requisite_profile/_form.html.twig', {'button_label': 'Сохранить'}) }}
        </div>
    </section>
{% endblock %}
