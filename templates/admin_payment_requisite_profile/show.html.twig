{% extends 'admin/base.html.twig' %}

{% block title %}Платежные Реквизиты {{ payment_requisite_profile.name }}{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Платежные реквизиты {{ payment_requisite_profile.name }}</h1>
            <p class="text-secondary mb-0">
                {% if open_assignments %}
                    Профиль используется в открытых назначениях.
                {% else %}
                    Профиль можно назначить для новых квитанций.
                {% endif %}
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary" href="{{ path('app_admin_payment_requisite_profile_index') }}">К списку</a>
            <a class="btn btn-primary" href="{{ path('app_admin_payment_requisite_profile_edit', {'uuid': payment_requisite_profile.uuid}) }}">Изменить</a>
            {{ include('admin_payment_requisite_profile/_delete_form.html.twig') }}
        </div>
    </div>

    <section class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Код</dt>
                <dd class="col-sm-9"><code>{{ payment_requisite_profile.code }}</code></dd>

                <dt class="col-sm-3">Получатель</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.recipientName }}</dd>

                <dt class="col-sm-3">ИНН / КПП</dt>
                <dd class="col-sm-9">
                    {{ payment_requisite_profile.recipientInn ?: '—' }}
                    /
                    {{ payment_requisite_profile.recipientKpp ?: '—' }}
                </dd>

                <dt class="col-sm-3">Банк</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.bankName }}</dd>

                <dt class="col-sm-3">БИК</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.bankBik }}</dd>

                <dt class="col-sm-3">Корр. счет</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.bankCorrespondentAccount ?: '—' }}</dd>

                <dt class="col-sm-3">Расчетный счет</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.bankAccount }}</dd>

                <dt class="col-sm-3">Назначение платежа</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.paymentPurposeTemplate ?: 'Шаблон по умолчанию' }}</dd>

                <dt class="col-sm-3">Действует</dt>
                <dd class="col-sm-9">
                    {{ payment_requisite_profile.validFrom|date('d.m.Y') }} -
                    {{ payment_requisite_profile.validTo ? payment_requisite_profile.validTo|date('d.m.Y') : 'бессрочно' }}
                </dd>

                <dt class="col-sm-3">Создан</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.createdAt|workspace_datetime }}</dd>

                <dt class="col-sm-3">Обновлен</dt>
                <dd class="col-sm-9">{{ payment_requisite_profile.updatedAt|workspace_datetime }}</dd>
            </dl>
        </div>
    </section>

    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Назначить профиль</h2>

            <form method="post" action="{{ path('app_admin_payment_requisite_profile_assign_scope', {'uuid': payment_requisite_profile.uuid}) }}" class="row g-3 align-items-end">
                <input type="hidden" name="_token" value="{{ csrf_token('assign_scope' ~ payment_requisite_profile.uuid) }}">
                <div class="col-md-8">
                    <label class="form-label" for="payment-requisite-assignment-scope">Область применения</label>
                    <select class="form-select" id="payment-requisite-assignment-scope" name="accrual_type">
                        {% for value, label in assignment_scope_choices %}
                            <option value="{{ value }}">{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-primary w-100">Назначить профиль</button>
                </div>
            </form>
        </div>
    </section>

    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Открытые назначения этого профиля</h2>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Область</th>
                            <th>Действует с</th>
                            <th>Действует до</th>
                            <th>Назначено</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for assignment in open_assignments %}
                        <tr>
                            <td>{{ assignment.scopeLabel }}</td>
                            <td>{{ assignment.validFrom|date('d.m.Y') }}</td>
                            <td>{{ assignment.validTo ? assignment.validTo|date('d.m.Y') : 'бессрочно' }}</td>
                            <td>{{ assignment.assignedAt|workspace_datetime }}</td>
                            <td class="text-end">
                                <form method="post" action="{{ path('app_admin_payment_requisite_assignment_close', {'assignmentUuid': assignment.uuid}) }}" onsubmit="return confirm('Снять это назначение реквизитов?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('close_assignment' ~ assignment.uuid) }}">
                                    <button class="btn btn-sm btn-outline-danger">Снять</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-secondary py-4">Этот профиль сейчас не назначен.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>
{% endblock %}
