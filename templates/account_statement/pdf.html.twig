<!doctype html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <title>Квитанция № {{ statement.number }}</title>
    <style>
        @page {
            size: A4;
            margin: 12mm;
        }

        body {
            margin: 0;
            color: #111;
            font-family: "DejaVu Sans", sans-serif;
            font-size: 11px;
            line-height: 1.35;
        }

        h1,
        h2,
        h3,
        p {
            margin: 0;
        }

        h1 {
            font-size: 22px;
            line-height: 1.2;
        }

        h2 {
            margin: 14px 0 7px;
            font-size: 14px;
        }

        h3 {
            margin: 10px 0 6px;
            font-size: 12px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            padding: 5px 6px;
            border: 1px solid #cfd6df;
            vertical-align: top;
        }

        th {
            background: #f1f3f6;
            font-weight: bold;
            text-align: left;
        }

        .muted {
            color: #5f6b7a;
        }

        .right {
            text-align: right;
        }

        .header {
            padding-bottom: 12px;
            border-bottom: 2px solid #111;
        }

        .header-table td {
            padding: 0;
            border: 0;
        }

        .header-amount {
            width: 180px;
            text-align: right;
        }

        .header-amount strong {
            display: block;
            font-size: 20px;
        }

        .details th {
            width: 150px;
        }

        .payment-table td {
            border: 0;
            padding: 0;
        }

        .payment-details {
            padding-right: 16px;
        }

        .payment-qr {
            width: 265px;
            text-align: center;
        }

        .payment-qr img {
            width: 260px;
            height: 260px;
            border: 1px solid #111;
        }

        .summary td {
            width: 25%;
        }

        .summary span {
            display: block;
            color: #5f6b7a;
            font-size: 10px;
        }

        .summary strong {
            font-size: 13px;
        }

        .section {
            page-break-inside: avoid;
        }

        .warning {
            margin-top: 10px;
            padding: 7px 8px;
            border: 1px solid #946200;
            background: #fff4d6;
        }
    </style>
</head>
<body>
    <div class="header">
        <table class="header-table">
            <tr>
                <td>
                    <div class="muted">КомУчёт</div>
                    <h1>Квитанция № {{ statement.number }}</h1>
                    <p>{{ statement.workspaceName }} · участок {{ statement.accountNumber }}</p>
                </td>
                <td class="header-amount">
                    <div class="muted">Сумма к оплате</div>
                    <strong>{{ statement.amountToPay|number_format(2, ',', ' ') }} руб.</strong>
                </td>
            </tr>
        </table>
    </div>

    {% if statement.cancelled %}
        <div class="warning">
            Квитанция отменена {{ statement.cancelledAt|date('d.m.Y H:i') }}.
            {% if statement.cancellationReason %}
                Причина: {{ statement.cancellationReason }}
            {% endif %}
        </div>
    {% endif %}

    <div class="section">
        <h2>Реквизиты квитанции</h2>
        <table class="details">
            <tr>
                <th>Хозяйство</th>
                <td>{{ statement.workspaceName }}</td>
                <th>Участок</th>
                <td>{{ statement.accountNumber }}</td>
            </tr>
            <tr>
                <th>Дата квитанции</th>
                <td>{{ statement.statementDate|date('d.m.Y') }}</td>
                <th>Сформирована</th>
                <td>{{ statement.generatedAt|date('d.m.Y H:i') }}</td>
            </tr>
        </table>
    </div>

    {% if statement.hasPaymentRequisites() %}
        <div class="section">
            <h2>Платежные реквизиты</h2>
            <table class="payment-table">
                <tr>
                    <td class="payment-details">
                        <table class="details">
                            <tr>
                                <th>Получатель</th>
                                <td>{{ statement.paymentRecipientName }}</td>
                            </tr>
                            <tr>
                                <th>ИНН / КПП</th>
                                <td>{{ statement.paymentRecipientInn ?: '—' }} / {{ statement.paymentRecipientKpp ?: '—' }}</td>
                            </tr>
                            <tr>
                                <th>Банк</th>
                                <td>{{ statement.paymentBankName }}</td>
                            </tr>
                            <tr>
                                <th>БИК</th>
                                <td>{{ statement.paymentBankBik }}</td>
                            </tr>
                            <tr>
                                <th>Корр. счет</th>
                                <td>{{ statement.paymentBankCorrespondentAccount ?: '—' }}</td>
                            </tr>
                            <tr>
                                <th>Расчетный счет</th>
                                <td>{{ statement.paymentBankAccount }}</td>
                            </tr>
                            <tr>
                                <th>Назначение платежа</th>
                                <td>{{ statement.paymentPurpose ?: '—' }}</td>
                            </tr>
                        </table>
                    </td>
                    <td class="payment-qr">
                        {% if payment_qr_code %}
                            <img src="{{ payment_qr_code.dataUri }}" alt="QR-код оплаты квитанции № {{ statement.number }}">
                            <div class="muted">Сканируйте для оплаты</div>
                        {% endif %}
                    </td>
                </tr>
            </table>
        </div>
    {% endif %}

    <div class="section">
        <h2>Итог</h2>
        <table class="summary">
            <tr>
                <td><span>Начислено</span><strong>{{ statement.activeAccrualTotal|number_format(2, ',', ' ') }} руб.</strong></td>
                <td><span>Оплачено</span><strong>{{ statement.activePaymentTotal|number_format(2, ',', ' ') }} руб.</strong></td>
                <td><span>Баланс</span><strong>{{ statement.balanceAmount|number_format(2, ',', ' ') }} руб.</strong></td>
                <td><span>К оплате</span><strong>{{ statement.amountToPay|number_format(2, ',', ' ') }} руб.</strong></td>
            </tr>
        </table>
    </div>

    <div class="section">
        <h2>Начисления</h2>
        <table>
            <thead>
                <tr>
                    <th>Период</th>
                    <th>Тип</th>
                    <th>Комментарий</th>
                    <th class="right">Сумма</th>
                </tr>
            </thead>
            <tbody>
            {% for accrual in accruals %}
                <tr>
                    <td>{{ accrual.periodStart|date('d.m.Y') }} - {{ accrual.periodEnd|date('d.m.Y') }}</td>
                    <td>{{ accrual.type.label }}</td>
                    <td>{{ accrual.notes ?: '—' }}</td>
                    <td class="right">{{ accrual.amount|number_format(2, ',', ' ') }} руб.</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="muted">Начисления отсутствуют.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if electricity_registers is not empty or electricity_lines is not empty %}
        <div class="section">
            <h2>Расчет электроэнергии</h2>

            {% if electricity_registers is not empty %}
                <h3>Показания</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Счетчик</th>
                            <th>Зона</th>
                            <th>Предыдущее</th>
                            <th>Текущее</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for register in electricity_registers %}
                        <tr>
                            <td>
                                {{ register.electricityMeterModel ?: '—' }}
                                {% if register.electricityMeterSerialNumber %}
                                    № {{ register.electricityMeterSerialNumber }}
                                {% endif %}
                            </td>
                            <td>{{ register.tariffZoneName }}</td>
                            <td>
                                {% if register.previousReadingValue is not null %}
                                    {{ register.previousReadingValue|number_format(3, ',', ' ') }} кВт⋅ч, {{ register.previousReadingTakenOn|date('d.m.Y') }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td>{{ register.currentReadingValue|number_format(3, ',', ' ') }} кВт⋅ч, {{ register.currentReadingTakenOn|date('d.m.Y') }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}

            {% if electricity_lines is not empty %}
                <h3>Строки расчета</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Зона</th>
                            <th>Диапазон</th>
                            <th>Расход</th>
                            <th>Ставка</th>
                            <th class="right">Сумма</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for line in electricity_lines %}
                        <tr>
                            <td>{{ line.tariffZoneName }}</td>
                            <td>{{ line.consumptionBandName }}</td>
                            <td>{{ line.consumptionKwh|number_format(3, ',', ' ') }} кВт⋅ч</td>
                            <td>{{ line.rate|number_format(6, ',', ' ') }} руб.</td>
                            <td class="right">{{ line.amount|number_format(2, ',', ' ') }} руб.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    {% endif %}

    <div class="section">
        <h2>Оплаты</h2>
        <table>
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Источник</th>
                    <th>Плательщик</th>
                    <th>Назначение</th>
                    <th class="right">Сумма</th>
                </tr>
            </thead>
            <tbody>
            {% for payment in payments %}
                <tr>
                    <td>{{ payment.paidOn|date('d.m.Y') }}</td>
                    <td>{{ payment.source.value == 'import' ? 'Импорт' : 'Ручной ввод' }}</td>
                    <td>{{ payment.payerName ?: '—' }}</td>
                    <td>{{ payment.purpose ?: '—' }}</td>
                    <td class="right">{{ payment.amount|number_format(2, ',', ' ') }} руб.</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="muted">Оплаты отсутствуют.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
