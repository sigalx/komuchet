<div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Квитанция № {{ statement.number }}</h1>
        <p class="text-secondary mb-0">{{ statement.workspaceName }} · участок {{ statement.accountNumber }} · {{ statement.statementDate|date('d.m.Y') }}</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        {% if pdf_url is defined %}
            <a class="btn btn-primary" href="{{ pdf_url }}">PDF</a>
        {% endif %}
        {% if print_url is defined %}
            <a class="btn btn-outline-primary" href="{{ print_url }}">Печатная версия</a>
        {% endif %}
        {% if delivery_enqueue_url is defined and not statement.cancelled %}
            <form method="post" action="{{ delivery_enqueue_url }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('enqueue_statement_delivery' ~ statement.uuid) }}">
                <button type="submit" class="btn btn-outline-success">Поставить в очередь отправки</button>
            </form>
        {% endif %}
        <a class="btn btn-outline-secondary" href="{{ back_url }}">{{ back_label }}</a>
    </div>
</div>

{% if statement.cancelled %}
    <div class="alert alert-warning">
        Квитанция отменена {{ statement.cancelledAt|date('d.m.Y H:i') }}.
        {% if statement.cancellationReason %}
            <div class="mt-1">Причина: {{ statement.cancellationReason }}</div>
        {% endif %}
    </div>
{% endif %}

<div class="row g-4">
    <div class="col-12 col-xl-7">
        <section class="card h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Итог</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Начислено</dt>
                    <dd class="col-sm-7">{{ statement.activeAccrualTotal|number_format(2, ',', ' ') }} руб.</dd>

                    <dt class="col-sm-5">Оплачено</dt>
                    <dd class="col-sm-7">{{ statement.activePaymentTotal|number_format(2, ',', ' ') }} руб.</dd>

                    <dt class="col-sm-5">Баланс</dt>
                    <dd class="col-sm-7">
                        <span class="fw-semibold">{{ statement.balanceAmount|number_format(2, ',', ' ') }} руб.</span>
                        {% if statement.hasDebt %}
                            <span class="badge text-bg-warning ms-2">К оплате</span>
                        {% elseif statement.hasOverpayment %}
                            <span class="badge text-bg-info ms-2">Переплата</span>
                        {% else %}
                            <span class="badge text-bg-success ms-2">Закрыто</span>
                        {% endif %}
                    </dd>

                    <dt class="col-sm-5">Сумма к оплате</dt>
                    <dd class="col-sm-7 display-6 mb-0">{{ statement.amountToPay|number_format(2, ',', ' ') }} руб.</dd>
                </dl>
            </div>
        </section>
    </div>

    <div class="col-12 col-xl-5">
        <section class="card h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Реквизиты</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Хозяйство</dt>
                    <dd class="col-sm-7">{{ statement.workspaceName }}</dd>

                    <dt class="col-sm-5">Участок</dt>
                    <dd class="col-sm-7">{{ statement.accountNumber }}</dd>

                    <dt class="col-sm-5">Дата</dt>
                    <dd class="col-sm-7">{{ statement.statementDate|date('d.m.Y') }}</dd>

                    <dt class="col-sm-5">Сформирована</dt>
                    <dd class="col-sm-7">{{ statement.generatedAt|date('d.m.Y H:i') }}</dd>
                </dl>
            </div>
        </section>
    </div>
</div>

{% if deliveries is defined %}
    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Доставка</h2>
        </div>

        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Получатель</th>
                        <th>Канал</th>
                        <th>Статус</th>
                        <th>Создана</th>
                        <th>Последняя попытка</th>
                    </tr>
                </thead>
                <tbody>
                {% for delivery in deliveries %}
                    {% set latest_attempt = delivery.latestAttempt %}
                    <tr>
                        <td>
                            <div>{{ delivery.recipientName ?: '—' }}</div>
                            <div class="small text-secondary">{{ delivery.recipientEmail }}</div>
                        </td>
                        <td>{{ delivery.channel.label }}</td>
                        <td>
                            <span class="badge {{ delivery.statusBadgeClass }}">{{ delivery.statusLabel }}</span>
                            {% if delivery.cancelledAt and delivery.cancellationReason %}
                                <div class="small text-secondary mt-1">{{ delivery.cancellationReason }}</div>
                            {% endif %}
                        </td>
                        <td>{{ delivery.createdAt|date('d.m.Y H:i') }}</td>
                        <td>
                            {% if latest_attempt %}
                                <div>№ {{ latest_attempt.attemptNumber }} · {{ latest_attempt.statusLabel }}</div>
                                <div class="small text-secondary">{{ latest_attempt.queuedAt|date('d.m.Y H:i') }}</div>
                                {% if latest_attempt.failureReason %}
                                    <div class="small text-danger">{{ latest_attempt.failureReason }}</div>
                                {% endif %}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-4">Отправки пока не создавались.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endif %}

{% if cancel_form is defined and not statement.cancelled %}
    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Отменить квитанцию</h2>
            {{ form_start(cancel_form) }}
                {{ form_row(cancel_form.reason) }}
                <button type="submit" class="btn btn-outline-danger">Отменить</button>
            {{ form_end(cancel_form) }}
        </div>
    </section>
{% endif %}

{% if statement.hasPaymentRequisites() %}
    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Платежные реквизиты</h2>
            <div class="row g-4 align-items-start">
                <div class="col-12 col-lg-8">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Получатель</dt>
                        <dd class="col-sm-9">{{ statement.paymentRecipientName }}</dd>

                        <dt class="col-sm-3">ИНН / КПП</dt>
                        <dd class="col-sm-9">
                            {{ statement.paymentRecipientInn ?: '—' }}
                            /
                            {{ statement.paymentRecipientKpp ?: '—' }}
                        </dd>

                        <dt class="col-sm-3">Банк</dt>
                        <dd class="col-sm-9">{{ statement.paymentBankName }}</dd>

                        <dt class="col-sm-3">БИК</dt>
                        <dd class="col-sm-9">{{ statement.paymentBankBik }}</dd>

                        <dt class="col-sm-3">Корр. счет</dt>
                        <dd class="col-sm-9">{{ statement.paymentBankCorrespondentAccount ?: '—' }}</dd>

                        <dt class="col-sm-3">Расчетный счет</dt>
                        <dd class="col-sm-9">{{ statement.paymentBankAccount }}</dd>

                        <dt class="col-sm-3">Назначение платежа</dt>
                        <dd class="col-sm-9">{{ statement.paymentPurpose ?: '—' }}</dd>
                    </dl>
                </div>

                {% if payment_qr_code is defined and payment_qr_code %}
                    <div class="col-12 col-lg-4">
                        <div class="statement-payment-qr">
                            <img src="{{ payment_qr_code.dataUri }}" alt="QR-код оплаты квитанции № {{ statement.number }}">
                            <div class="small text-secondary mt-2">QR-код сформирован из сохраненных реквизитов квитанции.</div>
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endif %}

<section class="card mt-4">
    <div class="card-body">
        <h2 class="h5 mb-3">Начисления</h2>
    </div>

    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Период</th>
                    <th>Тип</th>
                    <th>Комментарий</th>
                    <th class="text-end">Сумма</th>
                </tr>
            </thead>
            <tbody>
            {% for accrual in accruals %}
                <tr>
                    <td>{{ accrual.periodStart|date('d.m.Y') }} - {{ accrual.periodEnd|date('d.m.Y') }}</td>
                    <td>{{ accrual.type.label }}</td>
                    <td class="text-secondary">{{ accrual.notes ?: '—' }}</td>
                    <td class="text-end">{{ accrual.amount|number_format(2, ',', ' ') }} руб.</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="text-center text-secondary py-4">Начисления отсутствуют.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>

{% if electricity_registers is not empty or electricity_lines is not empty %}
    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Расчет электроэнергии</h2>

            {% if electricity_registers is not empty %}
                <h3 class="h6 mb-3">Показания</h3>
                <div class="table-responsive mb-4">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Счетчик</th>
                                <th>Зона</th>
                                <th>Предыдущее</th>
                                <th>Текущее</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for register in electricity_registers %}
                            <tr>
                                <td>
                                    {{ register.electricityMeterModel ?: '—' }}
                                    {% if register.electricityMeterSerialNumber %}
                                        <span class="text-secondary">№ {{ register.electricityMeterSerialNumber }}</span>
                                    {% endif %}
                                </td>
                                <td>{{ register.tariffZoneName }}</td>
                                <td>
                                    {% if register.previousReadingValue is not null %}
                                        {{ register.previousReadingValue|number_format(3, ',', ' ') }} кВт⋅ч, {{ register.previousReadingTakenOn|date('d.m.Y') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>{{ register.currentReadingValue|number_format(3, ',', ' ') }} кВт⋅ч, {{ register.currentReadingTakenOn|date('d.m.Y') }}</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}

            {% if electricity_lines is not empty %}
                <h3 class="h6 mb-3">Строки расчета</h3>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Зона</th>
                                <th>Диапазон</th>
                                <th>Расход</th>
                                <th>Ставка</th>
                                <th class="text-end">Сумма</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for line in electricity_lines %}
                            <tr>
                                <td>{{ line.tariffZoneName }}</td>
                                <td>{{ line.consumptionBandName }}</td>
                                <td>{{ line.consumptionKwh|number_format(3, ',', ' ') }} кВт⋅ч</td>
                                <td>{{ line.rate|number_format(6, ',', ' ') }} руб.</td>
                                <td class="text-end">{{ line.amount|number_format(2, ',', ' ') }} руб.</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </section>
{% endif %}

<section class="card mt-4">
    <div class="card-body">
        <h2 class="h5 mb-3">Оплаты</h2>
    </div>

    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Источник</th>
                    <th>Плательщик</th>
                    <th>Назначение</th>
                    <th class="text-end">Сумма</th>
                </tr>
            </thead>
            <tbody>
            {% for payment in payments %}
                <tr>
                    <td>{{ payment.paidOn|date('d.m.Y') }}</td>
                    <td>{{ payment.source.value == 'import' ? 'Импорт' : 'Ручной ввод' }}</td>
                    <td>{{ payment.payerName ?: '—' }}</td>
                    <td class="text-secondary">{{ payment.purpose ?: '—' }}</td>
                    <td class="text-end">{{ payment.amount|number_format(2, ',', ' ') }} руб.</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center text-secondary py-4">Оплаты отсутствуют.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>
