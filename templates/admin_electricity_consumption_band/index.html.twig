{% extends 'admin/base.html.twig' %}

{% block title %}Диапазоны Потребления{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Диапазоны потребления</h1>
            <p class="text-secondary mb-0">Диапазоны для расчета ставок: социальная норма, сверх социальной нормы и другие.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_admin_electricity_consumption_band_new') }}">Создать диапазон</a>
    </div>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'code', label: 'Код', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'name', label: 'Название', sort: sort}) }}</th>
                        <th>Описание</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'sort_order', label: 'Сортировка', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'updated_at', label: 'Обновлен', sort: sort}) }}</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for electricity_consumption_band in electricity_consumption_bands %}
                    <tr>
                        <td><code>{{ electricity_consumption_band.code }}</code></td>
                        <td class="fw-semibold">{{ electricity_consumption_band.name }}</td>
                        <td class="text-secondary">{{ electricity_consumption_band.description ?: '—' }}</td>
                        <td>{{ electricity_consumption_band.sortOrder }}</td>
                        <td>{{ electricity_consumption_band.updatedAt|workspace_datetime }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_consumption_band_show', {'uuid': electricity_consumption_band.uuid}) }}">Открыть</a>
                                <a class="btn btn-outline-primary" href="{{ path('app_admin_electricity_consumption_band_edit', {'uuid': electricity_consumption_band.uuid}) }}">Изменить</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-secondary py-5">Диапазоны потребления пока не созданы.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
