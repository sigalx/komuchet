{% extends 'admin/base.html.twig' %}

{% block title %}Диапазон Потребления {{ electricity_consumption_band.name }}{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Диапазон потребления {{ electricity_consumption_band.name }}</h1>
            <p class="text-secondary mb-0">{{ electricity_consumption_band.description ?: 'Без описания' }}</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_consumption_band_index') }}">К списку</a>
            <a class="btn btn-primary" href="{{ path('app_admin_electricity_consumption_band_edit', {'uuid': electricity_consumption_band.uuid}) }}">Изменить</a>
        </div>
    </div>

    <section class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Код</dt>
                <dd class="col-sm-9"><code>{{ electricity_consumption_band.code }}</code></dd>

                <dt class="col-sm-3">Название</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band.name }}</dd>

                <dt class="col-sm-3">Описание</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band.description ?: '—' }}</dd>

                <dt class="col-sm-3">Порядок сортировки</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band.sortOrder }}</dd>

                <dt class="col-sm-3">Создан</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band.createdAt|workspace_datetime }}</dd>

                <dt class="col-sm-3">Обновлен</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band.updatedAt|workspace_datetime }}</dd>
            </dl>
        </div>
    </section>
{% endblock %}
