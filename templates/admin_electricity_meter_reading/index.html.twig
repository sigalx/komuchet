{% extends 'admin/base.html.twig' %}

{% block title %}Показания Электросчетчиков{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Показания электросчетчиков</h1>
            <p class="text-secondary mb-0">Последние 300 событий передачи показаний по текущему хозяйству.</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_meter_index') }}">К счетчикам</a>
    </div>

    <section class="card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('app_admin_electricity_meter_reading_index') }}" class="row g-3 align-items-end">
                <input type="hidden" name="sort" value="{{ sort.field }}">
                <input type="hidden" name="dir" value="{{ sort.dir }}">

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="meter-reading-search-filter" class="form-label">Поиск</label>
                    <input id="meter-reading-search-filter" class="form-control" type="search" name="q" value="{{ filters.q }}" placeholder="Участок, счетчик или заметка">
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="meter-reading-zone-filter" class="form-label">Зона</label>
                    <select id="meter-reading-zone-filter" class="form-select" name="tariff_zone_uuid">
                        <option value="">Все зоны</option>
                        {% for tariff_zone in tariff_zones %}
                            {% set tariff_zone_uuid = tariff_zone.uuid.toRfc4122() %}
                            <option value="{{ tariff_zone_uuid }}" {{ filters.tariff_zone_uuid == tariff_zone_uuid ? 'selected' }}>
                                {{ tariff_zone.name }} ({{ tariff_zone.code }})
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="meter-reading-status-filter" class="form-label">Статус</label>
                    <select id="meter-reading-status-filter" class="form-select" name="status">
                        <option value="all" {{ filters.status == 'all' ? 'selected' }}>Все показания</option>
                        <option value="active" {{ filters.status == 'active' ? 'selected' }}>Активные</option>
                        <option value="cancelled" {{ filters.status == 'cancelled' ? 'selected' }}>Отмененные</option>
                        <option value="superseded" {{ filters.status == 'superseded' ? 'selected' }}>Замененные</option>
                    </select>
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="meter-reading-from-filter" class="form-label">С даты</label>
                    <input id="meter-reading-from-filter" class="form-control js-date-picker" type="text" name="taken_on_from" value="{{ filters.taken_on_from }}" placeholder="дд.мм.гггг" autocomplete="off">
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="meter-reading-to-filter" class="form-label">По дату</label>
                    <input id="meter-reading-to-filter" class="form-control js-date-picker" type="text" name="taken_on_to" value="{{ filters.taken_on_to }}" placeholder="дд.мм.гггг" autocomplete="off">
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-fill">Применить</button>
                        <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_meter_reading_index') }}">Сбросить</a>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'account_number', label: 'Участок', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'serial_number', label: 'Счетчик', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'tariff_zone', label: 'Зона', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'taken_on', label: 'Дата снятия', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'reading_value', label: 'Показание', sort: sort}) }}</th>
                        <th>Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for reading in electricity_meter_readings %}
                    <tr>
                        <td>
                            <a href="{{ path('app_admin_account_show', {'uuid': reading.electricityMeter.account.uuid}) }}">{{ reading.electricityMeter.account.number }}</a>
                        </td>
                        <td>
                            <a href="{{ path('app_admin_electricity_meter_show', {'uuid': reading.electricityMeter.uuid}) }}">{{ reading.electricityMeter.serialNumber ?: 'серийный номер не указан' }}</a>
                        </td>
                        <td><code>{{ reading.tariffZone.code }}</code></td>
                        <td>{{ reading.takenOn|date('d.m.Y') }}</td>
                        <td>{{ reading.readingValue|number_format(3, ',', ' ') }}</td>
                        <td>
                            {% if reading.cancelledAt %}
                                <span class="badge text-bg-danger">Отменено</span>
                            {% elseif reading.replacingReading %}
                                <span class="badge text-bg-secondary">Заменено</span>
                            {% else %}
                                <span class="badge text-bg-success">Активно</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_electricity_meter_reading_show', {'uuid': reading.uuid}) }}">Открыть</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-secondary py-5">
                            {% if filters.q or filters.status != 'all' or filters.tariff_zone_uuid or filters.taken_on_from or filters.taken_on_to %}
                                Показания не найдены.
                            {% else %}
                                Показания пока не внесены.
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
