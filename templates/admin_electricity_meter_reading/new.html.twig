{% extends 'admin/base.html.twig' %}

{% block title %}Новое Показание{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Новое показание</h1>
            <p class="text-secondary mb-0">Участок {{ electricity_meter.account.number }}, счетчик {{ electricity_meter.serialNumber ?: 'серийный номер не указан' }}</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_meter_show', {'uuid': electricity_meter.uuid}) }}">К счетчику</a>
    </div>

    <section class="card">
        <div class="card-body">
            {{ include('admin_electricity_meter_reading/_form.html.twig') }}
        </div>
    </section>
{% endblock %}
