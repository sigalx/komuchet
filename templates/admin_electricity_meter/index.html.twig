{% extends 'admin/base.html.twig' %}

{% block title %}Электросчетчики{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Электросчетчики</h1>
            <p class="text-secondary mb-0">Счетчики, установленные на участках, и их тарифные зоны.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_admin_electricity_meter_new') }}">Добавить счетчик</a>
    </div>

    <section class="card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('app_admin_electricity_meter_index') }}" class="row g-3 align-items-end">
                <input type="hidden" name="sort" value="{{ sort.field }}">
                <input type="hidden" name="dir" value="{{ sort.dir }}">

                <div class="col-12 col-lg-6">
                    <label for="electricity-meter-search-filter" class="form-label">Поиск</label>
                    <input id="electricity-meter-search-filter" class="form-control" type="search" name="q" value="{{ filters.q }}" placeholder="Участок, серийный номер, модель или заметка">
                </div>

                <div class="col-12 col-lg-3">
                    <label for="electricity-meter-status-filter" class="form-label">Статус</label>
                    <select id="electricity-meter-status-filter" class="form-select" name="status">
                        <option value="all" {{ filters.status == 'all' ? 'selected' }}>Все счетчики</option>
                        <option value="active" {{ filters.status == 'active' ? 'selected' }}>Активные</option>
                        <option value="removed" {{ filters.status == 'removed' ? 'selected' }}>Снятые</option>
                    </select>
                </div>

                <div class="col-12 col-lg-3">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-fill">Применить</button>
                        <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_meter_index') }}">Сбросить</a>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'account_number', label: 'Участок', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'serial_number', label: 'Серийный номер', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'model', label: 'Модель', sort: sort}) }}</th>
                        <th>Регистры</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'installed_on', label: 'Установлен', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'removed_on', label: 'Снят', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'verification_valid_until', label: 'Поверка до', sort: sort}) }}</th>
                        <th>Статус</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for electricity_meter in electricity_meters %}
                    {% set meter_uuid = electricity_meter.uuid.toRfc4122 %}
                    {% set registers = registers_by_meter[meter_uuid] ?? [] %}
                    <tr>
                        <td class="fw-semibold">{{ electricity_meter.account.number }}</td>
                        <td>{{ electricity_meter.serialNumber ?: '—' }}</td>
                        <td>{{ electricity_meter.model ?: '—' }}</td>
                        <td>
                            {% for register in registers %}
                                <span class="badge text-bg-light border">{{ register.tariffZone.code }}</span>
                            {% else %}
                                <span class="text-secondary">—</span>
                            {% endfor %}
                        </td>
                        <td>{{ electricity_meter.installedOn|date('d.m.Y') }}</td>
                        <td>{{ electricity_meter.removedOn ? electricity_meter.removedOn|date('d.m.Y') : '—' }}</td>
                        <td>{{ electricity_meter.verificationValidUntil ? electricity_meter.verificationValidUntil|date('d.m.Y') : '—' }}</td>
                        <td>
                            {% if electricity_meter.removedOn %}
                                <span class="badge text-bg-secondary">Снят</span>
                            {% else %}
                                <span class="badge text-bg-success">Активен</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_meter_show', {'uuid': electricity_meter.uuid}) }}">Открыть</a>
                                <a class="btn btn-outline-primary" href="{{ path('app_admin_electricity_meter_edit', {'uuid': electricity_meter.uuid}) }}">Изменить</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center text-secondary py-5">
                            {% if filters.q or filters.status != 'all' %}
                                Электросчетчики не найдены.
                            {% else %}
                                Электросчетчики пока не созданы.
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
