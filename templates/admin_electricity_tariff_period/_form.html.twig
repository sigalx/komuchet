{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-6">
            {{ form_row(form.validFrom) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.validTo) }}
        </div>
        <div class="col-12">
            {{ form_row(form.sourceDocument) }}
        </div>
        <div class="col-12">
            {{ form_row(form.notes) }}
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary">{{ button_label|default('Сохранить') }}</button>
        <a class="btn btn-outline-secondary" href="{{ cancel_path }}">Отмена</a>
    </div>
{{ form_end(form) }}
