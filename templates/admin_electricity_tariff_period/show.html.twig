{% extends 'admin/base.html.twig' %}

{% block title %}Тарифный Период {{ electricity_tariff_profile.name }}{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Тарифный период</h1>
            <p class="text-secondary mb-0">
                Профиль:
                <a href="{{ path('app_admin_electricity_tariff_profile_show', {'uuid': electricity_tariff_profile.uuid}) }}">{{ electricity_tariff_profile.name }}</a>
            </p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_tariff_profile_show', {'uuid': electricity_tariff_profile.uuid}) }}">К профилю</a>
            <a class="btn btn-primary" href="{{ path('app_admin_electricity_tariff_period_edit', {'uuid': electricity_tariff_period.uuid}) }}">Изменить</a>
        </div>
    </div>

    <section class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Действует с</dt>
                <dd class="col-sm-9">{{ electricity_tariff_period.validFrom|date('d.m.Y') }}</dd>

                <dt class="col-sm-3">Действует до</dt>
                <dd class="col-sm-9">{{ electricity_tariff_period.validTo ? electricity_tariff_period.validTo|date('d.m.Y') : 'бессрочно' }}</dd>

                <dt class="col-sm-3">Документ-основание</dt>
                <dd class="col-sm-9">{{ electricity_tariff_period.sourceDocument ?: '—' }}</dd>

                <dt class="col-sm-3">Заметки</dt>
                <dd class="col-sm-9">{{ electricity_tariff_period.notes ?: '—' }}</dd>

                <dt class="col-sm-3">Создан</dt>
                <dd class="col-sm-9">{{ electricity_tariff_period.createdAt|workspace_datetime }}</dd>

                <dt class="col-sm-3">Обновлен</dt>
                <dd class="col-sm-9">{{ electricity_tariff_period.updatedAt|workspace_datetime }}</dd>
            </dl>
        </div>
    </section>

    <section class="card mt-4">
        <div class="card-body">
            <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
                <div>
                    <h2 class="h5 mb-1">Ставки</h2>
                    <p class="text-secondary mb-0">Ставка задается для пары “тарифная зона + диапазон потребления”.</p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Тарифная зона</th>
                            <th>Диапазон потребления</th>
                            <th>Ставка</th>
                            <th>Обновлена</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for tariff_rate in tariff_rates %}
                        <tr>
                            <td>
                                <code>{{ tariff_rate.tariffZone.code }}</code>
                                <span class="ms-1">{{ tariff_rate.tariffZone.name }}</span>
                            </td>
                            <td>
                                <code>{{ tariff_rate.consumptionBand.code }}</code>
                                <span class="ms-1">{{ tariff_rate.consumptionBand.name }}</span>
                            </td>
                            <td>{{ tariff_rate.rate|number_format(6, ',', ' ') }} руб/кВт⋅ч</td>
                            <td>{{ tariff_rate.updatedAt|workspace_datetime }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-secondary py-4">Ставки для периода пока не заданы.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Добавить или обновить ставку</h2>

            {% if rate_form.tariffZone.vars.choices|length == 0 %}
                <div class="alert alert-warning mb-0">Сначала нужно создать хотя бы одну тарифную зону.</div>
            {% elseif rate_form.consumptionBand.vars.choices|length == 0 %}
                <div class="alert alert-warning mb-0">Сначала нужно создать хотя бы один диапазон потребления.</div>
            {% else %}
                {{ form_start(rate_form) }}
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            {{ form_row(rate_form.tariffZone) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_row(rate_form.consumptionBand) }}
                        </div>
                        <div class="col-md-3">
                            {{ form_row(rate_form.rate) }}
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-primary w-100">OK</button>
                        </div>
                    </div>
                {{ form_end(rate_form) }}
            {% endif %}
        </div>
    </section>
{% endblock %}
