{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-4">
            {{ form_row(form.kind) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.periodStart) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.periodEnd) }}
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary">{{ button_label|default('Сохранить') }}</button>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_billing_run_index') }}">Отмена</a>
    </div>
{{ form_end(form) }}
