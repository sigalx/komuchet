{% extends 'admin/base.html.twig' %}

{% block title %}Расчеты{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Расчеты</h1>
            <p class="text-secondary mb-0">Последние 300 запусков расчета по текущему хозяйству.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_admin_billing_run_new') }}">Создать расчет</a>
    </div>

    <section class="card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('app_admin_billing_run_index') }}" class="row g-3 align-items-end">
                <input type="hidden" name="sort" value="{{ sort.field }}">
                <input type="hidden" name="dir" value="{{ sort.dir }}">

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-kind-filter" class="form-label">Тип</label>
                    <select id="billing-run-kind-filter" class="form-select" name="kind">
                        <option value="" {{ filters.kind == '' ? 'selected' }}>Все типы</option>
                        {% for billing_run_kind in billing_run_kinds %}
                            <option value="{{ billing_run_kind.value }}" {{ filters.kind == billing_run_kind.value ? 'selected' }}>{{ billing_run_kind.label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-status-filter" class="form-label">Статус</label>
                    <select id="billing-run-status-filter" class="form-select" name="status">
                        <option value="all" {{ filters.status == 'all' ? 'selected' }}>Все расчеты</option>
                        <option value="draft" {{ filters.status == 'draft' ? 'selected' }}>Черновики</option>
                        <option value="posted" {{ filters.status == 'posted' ? 'selected' }}>Проведенные</option>
                        <option value="cancelled" {{ filters.status == 'cancelled' ? 'selected' }}>Отмененные</option>
                    </select>
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-issues-filter" class="form-label">Проблемы</label>
                    <select id="billing-run-issues-filter" class="form-select" name="issues">
                        <option value="all" {{ filters.issues == 'all' ? 'selected' }}>Любые</option>
                        <option value="with_open" {{ filters.issues == 'with_open' ? 'selected' }}>Есть открытые</option>
                        <option value="without_open" {{ filters.issues == 'without_open' ? 'selected' }}>Нет открытых</option>
                    </select>
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-accruals-filter" class="form-label">Начисления</label>
                    <select id="billing-run-accruals-filter" class="form-select" name="accruals">
                        <option value="all" {{ filters.accruals == 'all' ? 'selected' }}>Любые</option>
                        <option value="with" {{ filters.accruals == 'with' ? 'selected' }}>Есть</option>
                        <option value="without" {{ filters.accruals == 'without' ? 'selected' }}>Нет</option>
                    </select>
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-period-start-from-filter" class="form-label">Период с</label>
                    <input id="billing-run-period-start-from-filter" class="form-control js-date-picker" type="text" name="period_start_from" value="{{ filters.period_start_from }}" placeholder="дд.мм.гггг" autocomplete="off">
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-period-start-to-filter" class="form-label">Период по</label>
                    <input id="billing-run-period-start-to-filter" class="form-control js-date-picker" type="text" name="period_start_to" value="{{ filters.period_start_to }}" placeholder="дд.мм.гггг" autocomplete="off">
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-generated-at-from-filter" class="form-label">Создан с</label>
                    <input id="billing-run-generated-at-from-filter" class="form-control js-date-picker" type="text" name="generated_at_from" value="{{ filters.generated_at_from }}" placeholder="дд.мм.гггг" autocomplete="off">
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <label for="billing-run-generated-at-to-filter" class="form-label">Создан по</label>
                    <input id="billing-run-generated-at-to-filter" class="form-control js-date-picker" type="text" name="generated_at_to" value="{{ filters.generated_at_to }}" placeholder="дд.мм.гггг" autocomplete="off">
                </div>

                <div class="col-12 col-xl-2 col-lg-6">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-fill">Применить</button>
                        <a class="btn btn-outline-secondary" href="{{ path('app_admin_billing_run_index') }}">Сбросить</a>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'period_start', label: 'Период', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'kind', label: 'Тип', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'generated_at', label: 'Создан', sort: sort}) }}</th>
                        <th>Статус</th>
                        <th>Проблемы</th>
                        <th>Начисления</th>
                        <th>Следующее действие</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for row in billing_run_rows %}
                    {% set billing_run = row.billing_run %}
                    <tr>
                        <td>{{ billing_run.periodStart|date('d.m.Y') }} - {{ billing_run.periodEnd|date('d.m.Y') }}</td>
                        <td>{{ billing_run.kind.label }}</td>
                        <td>{{ billing_run.generatedAt|workspace_datetime }}</td>
                        <td>
                            {% if billing_run.cancelled %}
                                <span class="badge text-bg-danger">Отменен</span>
                            {% elseif billing_run.posted %}
                                <span class="badge text-bg-success">Проведен</span>
                            {% else %}
                                <span class="badge text-bg-light border">Черновик</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if row.open_issue_count > 0 %}
                                <span class="badge text-bg-warning">{{ row.open_issue_count }}</span>
                            {% else %}
                                <span class="badge text-bg-light border">0</span>
                            {% endif %}
                        </td>
                        <td>{{ row.accrual_count }}</td>
                        <td>{{ row.next_action.title }}</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_billing_run_show', {'uuid': billing_run.uuid}) }}">Открыть</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-secondary py-5">
                            {% if filters.kind or filters.status != 'all' or filters.issues != 'all' or filters.accruals != 'all' or filters.period_start_from or filters.period_start_to or filters.generated_at_from or filters.generated_at_to %}
                                Расчеты не найдены.
                            {% else %}
                                Расчеты пока не создавались.
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
