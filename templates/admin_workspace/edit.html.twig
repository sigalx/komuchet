{% extends 'admin/base.html.twig' %}

{% block title %}Хозяйство {{ workspace.code }}{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Хозяйство {{ workspace.code }}</h1>
            <p class="text-secondary mb-0">Изменение кода, названия, описания и часового пояса.</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_workspace_show', {'uuid': workspace.uuid}) }}">К карточке</a>
    </div>

    <section class="card">
        <div class="card-body">
            {{ include('admin_workspace/_form.html.twig') }}
        </div>
    </section>
{% endblock %}
