{% extends 'admin/base.html.twig' %}

{% block title %}Хозяйства{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Хозяйства</h1>
            <p class="text-secondary mb-0">Изолированные контуры бизнес-данных внутри установки.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_admin_workspace_new') }}">Создать хозяйство</a>
    </div>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'code', label: 'Код', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'name', label: 'Название', sort: sort}) }}</th>
                        <th>Часовой пояс</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'updated_at', label: 'Обновлен', sort: sort}) }}</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for workspace in workspaces %}
                    <tr>
                        <td><code>{{ workspace.code }}</code></td>
                        <td>
                            <div class="fw-semibold">{{ workspace.name }}</div>
                            {% if workspace.description %}
                                <div class="small text-secondary">{{ workspace.description }}</div>
                            {% endif %}
                        </td>
                        <td>{{ workspace.timezone|russian_timezone_label }}</td>
                        <td>{{ workspace.updatedAt|workspace_datetime }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary" href="{{ path('app_admin_workspace_show', {'uuid': workspace.uuid}) }}">Открыть</a>
                                <a class="btn btn-outline-primary" href="{{ path('app_admin_workspace_edit', {'uuid': workspace.uuid}) }}">Изменить</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-5">Хозяйства пока не созданы.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
