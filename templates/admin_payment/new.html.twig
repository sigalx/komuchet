{% extends 'admin/base.html.twig' %}

{% block title %}Новая Оплата{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Новая оплата</h1>
            <p class="text-secondary mb-0">Участок {{ account.number }}</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_account_show', {'uuid': account.uuid}) }}">К участку</a>
    </div>

    <section class="card">
        <div class="card-body">
            {{ include('admin_payment/_form.html.twig') }}
        </div>
    </section>
{% endblock %}
