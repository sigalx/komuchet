{% extends 'admin/base.html.twig' %}

{% block title %}Группы Участков{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Группы участков</h1>
            <p class="text-secondary mb-0">Списки участков для норм, правил и отчетов.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_admin_account_group_new') }}">Создать группу</a>
    </div>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'code', label: 'Код', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'name', label: 'Название', sort: sort}) }}</th>
                        <th>Описание</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'updated_at', label: 'Обновлена', sort: sort}) }}</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for account_group in account_groups %}
                    <tr>
                        <td><code>{{ account_group.code }}</code></td>
                        <td class="fw-semibold">{{ account_group.name }}</td>
                        <td class="text-secondary">{{ account_group.description ?: '—' }}</td>
                        <td>{{ account_group.updatedAt|workspace_datetime }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary" href="{{ path('app_admin_account_group_show', {'uuid': account_group.uuid}) }}">Открыть</a>
                                <a class="btn btn-outline-primary" href="{{ path('app_admin_account_group_edit', {'uuid': account_group.uuid}) }}">Изменить</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-5">Группы участков пока не созданы.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
