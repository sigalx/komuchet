{% extends 'admin/base.html.twig' %}

{% set month_names = {
    1: 'Январь', 2: 'Февраль', 3: 'Март', 4: 'Апрель', 5: 'Май', 6: 'Июнь',
    7: 'Июль', 8: 'Август', 9: 'Сентябрь', 10: 'Октябрь', 11: 'Ноябрь', 12: 'Декабрь'
} %}

{% block title %}Правило Диапазонов Потребления{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Правило диапазонов потребления</h1>
            <p class="text-secondary mb-0">
                {{ electricity_consumption_band_rule.tariffProfile.name }},
                {{ month_names[electricity_consumption_band_rule.month]|lower }}
            </p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_consumption_band_rule_index') }}">К списку</a>
            <a class="btn btn-primary" href="{{ path('app_admin_electricity_consumption_band_rule_edit', {'uuid': electricity_consumption_band_rule.uuid}) }}">Изменить</a>
        </div>
    </div>

    <section class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Тарифный профиль</dt>
                <dd class="col-sm-9">
                    <a href="{{ path('app_admin_electricity_tariff_profile_show', {'uuid': electricity_consumption_band_rule.tariffProfile.uuid}) }}">{{ electricity_consumption_band_rule.tariffProfile.name }}</a>
                    <code class="ms-2">{{ electricity_consumption_band_rule.tariffProfile.code }}</code>
                </dd>

                <dt class="col-sm-3">Месяц</dt>
                <dd class="col-sm-9">{{ month_names[electricity_consumption_band_rule.month] }}</dd>

                <dt class="col-sm-3">Период действия</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band_rule.validFrom|date('d.m.Y') }} - {{ electricity_consumption_band_rule.validTo ? electricity_consumption_band_rule.validTo|date('d.m.Y') : 'бессрочно' }}</dd>

                <dt class="col-sm-3">Распределение</dt>
                <dd class="col-sm-9">
                    {% if electricity_consumption_band_rule.allocationMethod.value == 'total_proportional' %}
                        По общему потреблению, пропорционально зонам
                    {% else %}
                        Отдельно внутри каждой тарифной зоны
                    {% endif %}
                </dd>

                <dt class="col-sm-3">Приоритет</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band_rule.priority }}</dd>

                <dt class="col-sm-3">Область применения</dt>
                <dd class="col-sm-9">
                    {% if all_scope %}
                        Все участки
                    {% else %}
                        <span class="text-warning">Не задана</span>
                    {% endif %}
                </dd>

                <dt class="col-sm-3">Документ-основание</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band_rule.sourceDocument ?: '—' }}</dd>

                <dt class="col-sm-3">Заметки</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band_rule.notes ?: '—' }}</dd>

                <dt class="col-sm-3">Создано</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band_rule.createdAt|workspace_datetime }}</dd>

                <dt class="col-sm-3">Обновлено</dt>
                <dd class="col-sm-9">{{ electricity_consumption_band_rule.updatedAt|workspace_datetime }}</dd>
            </dl>
        </div>
    </section>

    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Диапазоны</h2>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Диапазон</th>
                            <th>Нижняя граница</th>
                            <th>Верхняя граница</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for range in rule_ranges %}
                        <tr>
                            <td>
                                <code>{{ range.consumptionBand.code }}</code>
                                <span class="ms-1">{{ range.consumptionBand.name }}</span>
                            </td>
                            <td>{{ range.lowerBoundKwh|number_format(3, ',', ' ') }} кВт⋅ч</td>
                            <td>{{ range.upperBoundKwh is null ? 'бесконечность' : range.upperBoundKwh|number_format(3, ',', ' ') ~ ' кВт⋅ч' }}</td>
                            <td class="text-end">
                                <form method="post" action="{{ path('app_admin_electricity_consumption_band_rule_range_delete', {'uuid': electricity_consumption_band_rule.uuid, 'bandUuid': range.consumptionBand.uuid}) }}" onsubmit="return confirm('Удалить диапазон {{ range.consumptionBand.name|e('js') }} из правила?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete-range' ~ electricity_consumption_band_rule.uuid ~ range.consumptionBand.uuid) }}">
                                    <button class="btn btn-sm btn-outline-danger">Удалить</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center text-secondary py-4">Диапазоны для правила пока не заданы.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="card mt-4">
        <div class="card-body">
            <h2 class="h5 mb-3">Добавить или обновить диапазон</h2>

            {% if range_form.consumptionBand.vars.choices|length == 0 %}
                <div class="alert alert-warning mb-0">Сначала нужно создать хотя бы один диапазон потребления.</div>
            {% else %}
                {{ form_start(range_form) }}
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            {{ form_row(range_form.consumptionBand) }}
                        </div>
                        <div class="col-md-3">
                            {{ form_row(range_form.lowerBoundKwh) }}
                        </div>
                        <div class="col-md-3">
                            {{ form_row(range_form.upperBoundKwh) }}
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary w-100">OK</button>
                        </div>
                    </div>
                {{ form_end(range_form) }}
            {% endif %}
        </div>
    </section>
{% endblock %}
