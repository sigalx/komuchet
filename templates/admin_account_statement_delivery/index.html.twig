{% extends 'admin/base.html.twig' %}

{% block title %}Доставка квитанций{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Доставка квитанций</h1>
            <p class="text-secondary mb-0">Очередь доставок сохраненных квитанций по email в текущем хозяйстве.</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_billing_run_index') }}">К расчетам</a>
    </div>

    <section class="card mb-4">
        <div class="card-body">
            <form method="get" action="{{ path('app_admin_account_statement_delivery_index') }}" class="row g-3 align-items-end">
                <input type="hidden" name="sort" value="{{ sort.field }}">
                <input type="hidden" name="dir" value="{{ sort.dir }}">

                <div class="col-12 col-lg-5">
                    <label for="delivery-search-filter" class="form-label">Поиск</label>
                    <input id="delivery-search-filter" class="form-control" type="search" name="q" value="{{ filters.q }}" placeholder="Участок, квитанция, email или получатель">
                </div>

                <div class="col-12 col-lg-3">
                    <label for="delivery-status-filter" class="form-label">Статус</label>
                    <select id="delivery-status-filter" class="form-select" name="status">
                        {% for value, label in status_choices %}
                            <option value="{{ value }}" {{ filters.status == value ? 'selected' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="col-12 col-lg-4">
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary flex-fill">Применить</button>
                        <a class="btn btn-outline-secondary" href="{{ path('app_admin_account_statement_delivery_index') }}">Сбросить</a>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'created_at', label: 'Создана', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'account_number', label: 'Участок', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'statement_number', label: 'Квитанция', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'recipient', label: 'Получатель', sort: sort}) }}</th>
                        <th>Статус</th>
                        <th>Попытка</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for delivery in deliveries %}
                    {% set statement = delivery.accountStatement %}
                    {% set account = statement ? statement.account : null %}
                    {% set latest_attempt = delivery.latestAttempt %}
                    <tr>
                        <td>{{ delivery.createdAt|workspace_datetime }}</td>
                        <td>
                            {% if account %}
                                <a href="{{ path('app_admin_account_show', {uuid: account.uuid}) }}">{{ statement.accountNumber }}</a>
                            {% else %}
                                {{ statement ? statement.accountNumber : '—' }}
                            {% endif %}
                        </td>
                        <td>
                            {% if statement and account %}
                                <a href="{{ path('app_admin_account_statement_snapshot_show', {uuid: account.uuid, statementUuid: statement.uuid}) }}">{{ statement.number }}</a>
                            {% elseif statement %}
                                {{ statement.number }}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            <div>{{ delivery.recipientName ?: '—' }}</div>
                            <div class="small text-secondary">{{ delivery.recipientEmail }}</div>
                        </td>
                        <td>
                            <span class="badge {{ delivery.statusBadgeClass }}">{{ delivery.statusLabel }}</span>
                            {% if delivery.cancelledAt %}
                                <div class="small text-secondary mt-1">{{ delivery.cancellationReason ?: '—' }}</div>
                            {% endif %}
                        </td>
                        <td>
                            {% if latest_attempt %}
                                <div>№ {{ latest_attempt.attemptNumber }}</div>
                                <div class="small text-secondary">
                                    {% if latest_attempt.succeededAt %}
                                        {{ latest_attempt.succeededAt|workspace_datetime }}
                                    {% elseif latest_attempt.failedAt %}
                                        {{ latest_attempt.failedAt|workspace_datetime }}
                                    {% elseif latest_attempt.startedAt %}
                                        {{ latest_attempt.startedAt|workspace_datetime }}
                                    {% else %}
                                        {{ latest_attempt.queuedAt|workspace_datetime }}
                                    {% endif %}
                                </div>
                                {% if latest_attempt.failureReason %}
                                    <div class="small text-danger mt-1">{{ latest_attempt.failureReason }}</div>
                                {% endif %}
                            {% else %}
                                <span class="text-secondary">—</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            {% if statement and account %}
                                <div class="btn-group btn-group-sm">
                                    <a class="btn btn-outline-secondary" href="{{ path('app_admin_account_statement_snapshot_show', {uuid: account.uuid, statementUuid: statement.uuid}) }}">Открыть</a>
                                    <a class="btn btn-outline-secondary" href="{{ path('app_admin_account_statement_snapshot_pdf', {uuid: account.uuid, statementUuid: statement.uuid}) }}">PDF</a>
                                </div>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-secondary py-5">
                            {% if filters.q or filters.status != 'all' %}
                                Доставки не найдены.
                            {% else %}
                                Доставки квитанций пока не создавались.
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
