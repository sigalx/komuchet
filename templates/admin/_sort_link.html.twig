{% set route_parameters = route_parameters|default({}) %}
{% set current_route = app.request.attributes.get('_route') %}
{% set current_sort = sort.field|default('') %}
{% set current_dir = sort.dir|default('asc') %}
{% set active = current_sort == field %}
{% set next_dir = active and current_dir == 'asc' ? 'desc' : 'asc' %}
<a class="link-dark text-decoration-none" href="{{ path(current_route, route_parameters|merge(app.request.query.all)|merge({sort: field, dir: next_dir, page: 1})) }}">
    {{ label }}
    {% if active %}
        <span class="small text-secondary">{{ current_dir == 'asc' ? '↑' : '↓' }}</span>
    {% endif %}
</a>
