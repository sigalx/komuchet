{% extends 'admin/base.html.twig' %}

{% block title %}Загрузка PDF ЗМ{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <a class="small text-decoration-none" href="{{ path('app_admin_zavety_michurina_statement_import_index') }}">← К пачкам импорта</a>
            <h1 class="h3 mt-2 mb-1">Загрузка PDF-квитанций ЗМ</h1>
            <p class="text-secondary mb-0">Файлы будут распознаны и сохранены в staging без применения к рабочей модели.</p>
        </div>
    </div>

    <section class="card">
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        {{ form_row(form.name) }}
                    </div>
                    <div class="col-12">
                        {{ form_row(form.files) }}
                    </div>
                </div>

                <div class="alert alert-info mt-3 mb-0">
                    Оригиналы PDF на этом шаге не сохраняются. В базе останутся hash, имя файла, размер и результат распознавания.
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a class="btn btn-outline-secondary" href="{{ path('app_admin_zavety_michurina_statement_import_index') }}">Отмена</a>
                    <button class="btn btn-primary">Загрузить и распознать</button>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
