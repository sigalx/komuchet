{% extends 'admin/base.html.twig' %}

{% block title %}Импорт PDF ЗМ{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Импорт PDF-квитанций ЗМ</h1>
            <p class="text-secondary mb-0">Пачки промежуточного разбора исторических квитанций.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge text-bg-light border fs-6">{{ pagination.totalItems }}</span>
            <a class="btn btn-primary" href="{{ path('app_admin_zavety_michurina_statement_import_new') }}">Загрузить PDF</a>
        </div>
    </div>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'created_at', label: 'Создана', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'name', label: 'Название', sort: sort}) }}</th>
                        <th>Файлы</th>
                        <th>Статусы</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for batch in batches %}
                    {% set summary = batch_summaries[batch.uuid.toRfc4122()] ?? {total: 0} %}
                    <tr>
                        <td>{{ batch.createdAt|workspace_datetime }}</td>
                        <td class="fw-semibold">
                            {{ batch.name ?: 'Пачка от ' ~ batch.createdAt|workspace_datetime('d.m.Y H:i') }}
                        </td>
                        <td>{{ summary.total ?? 0 }}</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                {% for status in status_cases %}
                                    {% set count = summary[status.value] ?? 0 %}
                                    {% if count > 0 %}
                                        <span class="badge {{ status.badgeClass() }}">{{ status.label() }}: {{ count }}</span>
                                    {% endif %}
                                {% endfor %}
                                {% if (summary.total ?? 0) == 0 %}
                                    <span class="badge text-bg-secondary">Нет файлов</span>
                                {% endif %}
                            </div>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_admin_zavety_michurina_statement_import_show', {uuid: batch.uuid}) }}">Открыть</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-5">Пачки импорта пока не созданы.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
