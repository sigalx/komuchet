{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-4">
            {{ form_row(form.lastName) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.firstName) }}
        </div>
        <div class="col-md-4">
            {{ form_row(form.secondName) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.contactEmail) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.contactPhone) }}
        </div>
        <div class="col-12">
            {{ form_row(form.notes) }}
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary">{{ button_label|default('Сохранить') }}</button>
        <a class="btn btn-outline-secondary" href="{{ path('app_admin_subscriber_index') }}">Отмена</a>
    </div>
{{ form_end(form) }}
