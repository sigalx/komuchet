<form method="post" action="{{ path('app_admin_subscriber_delete', {'uuid': subscriber.uuid}) }}" onsubmit="return confirm('Удалить абонента {{ subscriber.displayName|e('js') }}?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ subscriber.uuid) }}">
    <button class="btn btn-outline-danger">Удалить</button>
</form>
