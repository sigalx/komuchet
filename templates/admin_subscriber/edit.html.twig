        <div>
            <h1 class="h3 mb-1">Абонент {{ subscriber.displayName }}</h1>
            <p class="text-secondary mb-0">Изменение ФИО, контактов и служебной заметки.</p>
        </div>
        {{ include('admin_subscriber/_delete_form.html.twig') }}
