{% extends 'subscriber_portal/base.html.twig' %}

{% block title %}Личный кабинет · КомУчёт{% endblock %}

{% block portal_body %}
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Личный кабинет</h1>
            <div class="text-secondary">{{ subscriber.displayName }}</div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-secondary small mb-1">Хозяйство</div>
                    <div class="h5 mb-1">{{ current_workspace.name }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-secondary small mb-1">Участки</div>
                    <div class="h2 mb-0">{{ account_rows|length }}</div>
                </div>
            </div>
        </div>
    </div>

    <section class="card">
        <div class="card-header bg-white d-flex flex-wrap align-items-center justify-content-between gap-2">
            <h2 class="h5 mb-0">Участки</h2>
        </div>

        {% if account_rows is empty %}
            <div class="card-body text-secondary">Нет доступных участков.</div>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Участок</th>
                            <th scope="col">Доступ</th>
                            <th scope="col">Баланс</th>
                            <th scope="col">Электросчетчик</th>
                            <th scope="col" class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in account_rows %}
                            <tr>
                                <td class="fw-semibold">{{ row.account.number }}</td>
                                <td>{{ row.access.accessRole.label }}</td>
                                <td>
                                    {% if row.balance %}
                                        <span class="fw-semibold">{{ row.balance.balanceAmount|number_format(2, ',', ' ') }} руб.</span>
                                        {% if row.balance.state == 'debt' %}
                                            <span class="badge text-bg-warning ms-2">К оплате</span>
                                        {% elseif row.balance.state == 'overpayment' %}
                                            <span class="badge text-bg-info ms-2">Переплата</span>
                                        {% else %}
                                            <span class="badge text-bg-success ms-2">Закрыто</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-secondary">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if row.active_meter %}
                                        {{ row.active_meter.serialNumber ?: 'Без серийного номера' }}
                                    {% else %}
                                        <span class="text-secondary">Не установлен</span>
                                    {% endif %}
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                                        {% if row.active_meter %}
                                            <a class="btn btn-sm btn-primary" href="{{ path('app_subscriber_portal_account_reading_new', {'uuid': row.account.uuid}) }}">Передать показания</a>
                                        {% endif %}
                                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_subscriber_portal_account_show', {'uuid': row.account.uuid}) }}">Открыть</a>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </section>
{% endblock %}
