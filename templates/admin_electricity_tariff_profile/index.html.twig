{% extends 'admin/base.html.twig' %}

{% block title %}Тарифные Профили{% endblock %}

{% block admin_body %}
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Тарифные профили</h1>
            <p class="text-secondary mb-0">Категории тарификации участков: СНТ, город, сельская местность и другие.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('app_admin_electricity_tariff_profile_new') }}">Создать профиль</a>
    </div>

    <section class="card">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'code', label: 'Код', sort: sort}) }}</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'name', label: 'Название', sort: sort}) }}</th>
                        <th>Описание</th>
                        <th>{{ include('admin/_sort_link.html.twig', {field: 'updated_at', label: 'Обновлен', sort: sort}) }}</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                {% for electricity_tariff_profile in electricity_tariff_profiles %}
                    <tr>
                        <td><code>{{ electricity_tariff_profile.code }}</code></td>
                        <td class="fw-semibold">{{ electricity_tariff_profile.name }}</td>
                        <td class="text-secondary">{{ electricity_tariff_profile.description ?: '—' }}</td>
                        <td>{{ electricity_tariff_profile.updatedAt|workspace_datetime }}</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a class="btn btn-outline-secondary" href="{{ path('app_admin_electricity_tariff_profile_show', {'uuid': electricity_tariff_profile.uuid}) }}">Открыть</a>
                                <a class="btn btn-outline-primary" href="{{ path('app_admin_electricity_tariff_profile_edit', {'uuid': electricity_tariff_profile.uuid}) }}">Изменить</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary py-5">Тарифные профили пока не созданы.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        {{ include('admin/_pagination.html.twig', {pagination: pagination}) }}
    </section>
{% endblock %}
