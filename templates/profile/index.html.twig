{% extends 'base.html.twig' %}

{% block title %}Профиль{% endblock %}

{% block body %}
    <main class="auth-page">
        <section class="profile-panel">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-4">
                <div>
                    <h1 class="h3 mb-1">Профиль</h1>
                    <p class="text-secondary mb-0">{{ user.primaryEmail ?? 'Пользователь без email' }}</p>
                </div>
                <div class="d-flex flex-wrap justify-content-end gap-2">
                    {% if is_granted('SUBSCRIBER_PORTAL_ACCESS') %}
                        <a class="btn btn-outline-primary" href="{{ path('app_subscriber_portal') }}">Личный кабинет</a>
                    {% endif %}
                    {% if is_granted('WORKSPACE_ACCESS') %}
                        <a class="btn btn-outline-secondary" href="{{ path('app_admin') }}">Админка</a>
                    {% endif %}
                    <a class="btn btn-outline-secondary" href="{{ logout_path() }}">Выйти</a>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <section class="card h-100">
                        <div class="card-body">
                            <h2 class="h5 mb-3">Учетная запись</h2>

                            <dl class="row mb-0">
                                <dt class="col-sm-4">Состояние</dt>
                                <dd class="col-sm-8">{{ user.statusLabel }}</dd>

                                <dt class="col-sm-4">Создана</dt>
                                <dd class="col-sm-8">{{ user.createdAt|workspace_datetime }}</dd>

                                <dt class="col-sm-4">Пароль</dt>
                                <dd class="col-sm-8">
                                    {% if user.passwordCredential %}
                                        Установлен {{ user.passwordCredential.changedAt|workspace_datetime }}
                                        {% if user.passwordCredential.expiresAt %}
                                            <div class="small text-warning">Требуется смена пароля</div>
                                        {% endif %}
                                    {% else %}
                                        Не установлен
                                    {% endif %}
                                </dd>
                            </dl>

                            <div class="mt-3">
                                <a class="btn btn-primary" href="{{ path('app_password_change') }}">Сменить пароль</a>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="col-lg-6">
                    <section class="card h-100">
                        <div class="card-body">
                            <h2 class="h5 mb-3">Email-адреса</h2>

                            {% if active_email_identities %}
                                <div class="list-group list-group-flush">
                                    {% for identity in active_email_identities %}
                                        <div class="list-group-item px-0">
                                            <div class="fw-semibold">{{ identity.email }}</div>
                                            <div class="small text-secondary">
                                                {% if identity.verifiedAt %}
                                                    Подтвержден {{ identity.verifiedAt|workspace_datetime }}
                                                {% else %}
                                                    Не подтвержден
                                                {% endif %}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="text-secondary mb-0">Активные email-адреса не найдены.</p>
                            {% endif %}
                        </div>
                    </section>
                </div>
            </div>

            <section class="card mt-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Доступы к хозяйствам</h2>

                    {% if workspace_access_rows %}
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Хозяйство</th>
                                        <th>Доступ</th>
                                        <th>Абонент</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for row in workspace_access_rows %}
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">{{ row.workspace.name }}</div>
                                            </td>
                                            <td>
                                                <div class="d-flex flex-wrap gap-1">
                                                    {% for role_label in row.role_labels %}
                                                        <span class="badge text-bg-secondary">{{ role_label }}</span>
                                                    {% endfor %}
                                                    {% if row.subscriber %}
                                                        <span class="badge text-bg-primary">Абонент</span>
                                                    {% endif %}
                                                    {% if not row.role_labels and not row.subscriber %}
                                                        <span class="text-secondary">—</span>
                                                    {% endif %}
                                                </div>
                                            </td>
                                            <td>{{ row.subscriber ? row.subscriber.displayName : '—' }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-secondary mb-0">Доступы к хозяйствам не найдены.</p>
                    {% endif %}
                </div>
            </section>
        </section>
    </main>
{% endblock %}
